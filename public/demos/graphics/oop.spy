'''This memory game shows you how to use OOP in Strype and handle click on an Actor.'''
#(=> Section:Imports
from strype.graphics import * 
import random as rd 
#(=> Section:Definitions
#The number of pairs in the game
NUM_PAIRS  = 4 
class Card(Actor)  :
    '''The class representing a game card, it is an Actor that can be clicked to reveal an image.
    A card holds information about its face image id (the image is initially hidden), and its "flipped" status, 
    and its "paired" status (i.e. if it has been paired with another card).'''
    #(=> FrameState:FoldToHeader
    def __init__ (self,card_index,img_id ) :
        '''When a card is created, it is flipped: we only see its "back" image.
        Its position is based on its index.'''
        super().__init__(load_image("data:image/png;base64,"),-300+(card_index%NUM_PAIRS)*200,100 if card_index<NUM_PAIRS else -100) 
        self.is_flipped  = False 
        self.is_paired  = False 
        self.img_id  = img_id 
    #(=> FrameState:FoldToHeader
    def on_click (self, ) :
        '''When a card is clicked, it is flipped only if it is not already paired, and not already flipped.'''
        if ___strype_opsinvalid(___strype_blank,___strype_operator_u006eu006fu0074,self,___strype_operator_u002e,is_paired,___strype_operator_u0061u006eu0064,___strype_blank,___strype_operator_u006eu006fu0074,self,___strype_operator_u002e,is_flipped)  :
            #Flip the card
            self.is_flipped  = True 
            self.set_image(tree_tiles_img[self.img_id-1]) 
            #Let the pair monitor knows we about our action
            pairs_monitor.do_pair_building(self) 
    #(=> FrameState:FoldToHeader
    def flip_back (self, ) :
        '''Return the card, this function is called when a pair attempt was not successful'''
        self.set_image(load_image("data:image/png;base64,")) 
        self.is_flipped  = False 
class PairsMonitor  :
    '''This class helps the track pair building: when an attempt is made to match a pair, if a pair was sucessfully matched, and if all pairs have been matched.'''
    #(=> FrameState:FoldToHeader
    def __init__ (self, ) :
        '''Initialise the counters and the "first card" variable we need to keep trace of for checking pair matching.'''
        self.pair_building_counter  = 0 
        self.first_card  = None 
    #(=> FrameState:FoldToHeader
    def do_pair_building (self,clicked_card ) :
        if self.first_card is not None  :
            #A pair attempt is made: we check if that was successful or not
            if self.first_card.img_id==clicked_card.img_id  :
                #The pair was a match: we update the cards status and increment the pair building counter 
                self.first_card.is_paired  = True 
                clicked_card.is_paired  = True 
                self.pair_building_counter  = self.pair_building_counter+1 
            else :
                #The pair was not a match: we pause the game (to give enough time to look at the cards) and flip both cards back
                pause(1.5) 
                self.first_card.flip_back() 
                clicked_card.flip_back() 
            self.first_card  = None 
        else :
            self.first_card  = clicked_card 
    #(=> FrameState:FoldToHeader
    def is_game_won (self, ) :
        return self.pair_building_counter==NUM_PAIRS 
#(=> FrameState:FoldToHeader
def start_game ( ) :
    '''Entry point of the game, prepare the cards and starts the game'''
    #We generate random pair sequence
    img_id_sequence  = list(range(1,NUM_PAIRS+1))*2 
    rd.shuffle(img_id_sequence) 
    #Then, we create the game cards
    for card_index,card_img_id  in enumerate(img_id_sequence)  :
        Card(card_index,card_img_id) 
    #Now start the game
    while True  :
        #We check if a card has been clicked here:
        clicked_card  = get_clicked_actor() 
        if clicked_card is not None  :
            clicked_card.on_click() 
        #We check if the game is won
        if pairs_monitor.is_game_won()  :
            show_text("Well done",0,250,48) 
            stop() 
        pace(10) 
#(=> Section:Main
#First we create the pairs monitor object that will control the logic of the game
pairs_monitor  = PairsMonitor() 
#The images we'll use for the game
tree_tiles_img  = [load_image("data:image/jpeg;base64,"),load_image("data:image/jpeg;base64,"),load_image("data:image/jpeg;base64,"),load_image("data:image/jpeg;base64,")] 
start_game() 
#(=> Section:End
