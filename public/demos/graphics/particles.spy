'''Particles - a Strype example program.

This program shows a visual effect of glowing particles flying and reacting to gravity.

Author: Michael Kölling'''
#(=> Section:Imports
from strype.graphics import * 
import random 
#(=> Section:Definitions
#GRAVITY specifies how quickly particles fall
GRAVITY  = 0.5 
#FORCE controls the initial speed with which the particles fly outwards
FORCE  = 6 
particle_image  = load_image("data:image/png;base64,") 
def move (particle ) :
    '''Move a particle. If it hits the screen edge, remove it.'''
    if particle.is_at_edge()  :
        particle.remove() 
    else :
        particle.set_location(particle.get_x()+particle.dx,particle.get_y()-particle.dy) 
        particle.dy  = particle.dy+GRAVITY 
def create_particles ( ) :
    '''Create 10 new particles with random initial movement at the location of the mouse.'''
    mouse  = get_mouse() 
    for i  in range(10)  :
        particle  = Actor(particle_image,mouse.x,mouse.y) 
        #Instance variables: initial movement
        particle.dx  = random.gauss(0,1)*FORCE 
        particle.dy  = random.gauss(0,1)*FORCE 
#(=> Section:Main
set_background("Black") 
while True  :
    create_particles() 
    for p  in get_actors()  :
        move(p) 
    pace(30) 
#(=> Section:End
