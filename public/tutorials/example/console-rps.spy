'''Play the classic hand game... against Strype'''
#(=> Section:Tutorial
steps:
- title: "Welcome!"
  description: "In this tutorial we'll build a simple Rock–Paper–Scissors console game in Python. The player will compete against the computer with clear rules and input validation."
- title: "Game Rules"
  description: "Rock beats scissors, scissors beats paper, and paper beats rock. If both players choose the same move, the round is a tie."
- title: "Importing Random"
  description: "Import the random module so the computer can choose moves at random using `random.choice`."
- title: "Reading and Validating Input"
  description: "Implement `get_user_choice()` to prompt the player, normalize input to lowercase, and keep asking until a valid choice ('rock', 'paper', 'scissors') is entered."
- title: "Computer Move"
  description: "Implement `get_computer_choice()` to return a random move from the three options."
- title: "Determine Winner"
  description: "Write `determine_winner(user, computer)` to compare moves and return a message indicating win, loss, or tie."
- title: "Main Loop"
  description: "Combine the functions: get both choices, determine the result, print it, and optionally repeat for multiple rounds or track score."
- title: "Enhancements"
  description: "Add best-of-N series, short input aliases (r/p/s), score tracking, or a simple GUI (e.g., `tkinter`) as future improvements."
#(=> Section:Imports
import random 
#(=> Section:Definitions
def get_computer_choice ( ) :
    return random.choice(["rock","paper","scissors"]) 
def get_user_choice ( ) :
    choice  = input("Enter rock, paper, or scissors: ").lower() 
    while choice not in ["rock","paper","scissors"]  :
        print("Invalid input. Enter rock, paper or scissors.") 
        choice  = input("Enter rock, paper, or scissors: ").lower() 
    return choice 
def determine_winner (user,computer ) :
    print(___strype_invalid_u0066u0022u005cu006eu0059u006fu0075u0020u0063u0068u006fu0073u0065u0020u007bu0075u0073u0065u0072u007du002cu0020u0063u006fu006du0070u0075u0074u0065u0072u0020u0063u0068u006fu0073u0065u0020u007bu0063u006fu006du0070u0075u0074u0065u0072u007du002eu0022) 
    
    if user==computer  :
        return "It's a tie!" 
    elif user=="rock" and computer=="scissors"  :
        return "You win!" 
    elif user=="scissors" and computer=="paper"  :
        return "You win!" 
    elif user=="paper" and computer=="rock"  :
        return "You win!" 
    else :
        return "Computer wins!" 
#(=> Section:Main
user_choice  = get_user_choice() 
computer_choice  = get_computer_choice() 
result  = determine_winner(user_choice,computer_choice) 
print(result) 
#(=> Section:End
