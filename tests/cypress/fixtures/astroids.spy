#(=> Section:Imports
from strype.graphics import * 
from strype.sound import * 
from random import randint 
#(=> Section:Definitions
class Vector  :
    '''A 2D vector. The vector can be read and manipulated in Cartesian coordinates
    (as an x,y-offset pair) or in polar coordinates (as a direction and a length).'''
    def __init__ (self,angle=0.0,length=0,dx=0,dy=0 ) :
        if angle!=None  :
            self.angle,self.length  = angle,length 
            update_cartesian() 
        else :
            self.dx,self.dy  = dx,dy 
            update_polar() 
    def set_angle (self,angle ) :
        self.angle  = angle 
        update_cartesian() 
    def get_angle (self, ) :
        return self.angle 
    def set_length (self,length ) :
        self.length  = length 
        update_cartesian() 
    def get_length (self, ) :
        return self.length 
    def add (self,other ) :
        self.dx  = self.dx+other.dx 
        self.dy  = self.dy+other.dy 
        update_polar() 
    def scale (self,factor ) :
        length  = length*factor 
        update_cartesian() 
    def set_neutral (self, ) :
        self.dx,self.dy  = 0,0 
        self.direction,self.length  = 0,0.0 
    def update_polar (self, ) :
        self.angle  = math.degrees(math.atan2(dy,dx)) 
        self.length  = ___strype_opsinvalid(math,___strype_operator_u002e,hypot,___strype_operator_,(dx,dy),___strype_operator_,___strype_invalid_u003b) 
    def update_cartesian (self, ) :
        self.dx  = length*math.cos(math.radians(angle)) 
        self.dy  = ___strype_opsinvalid(length,___strype_operator_u002a,math,___strype_operator_u002e,sin,___strype_operator_,(math.radians(angle)),___strype_operator_,___strype_invalid_u003b) 
class FreeMover(Actor)  :
    def __init__ (self,img,x,y,tag,direction,speed ) :
        super().__init__(img,x,y,tag) 
        if direction  :
            self.set_rotation(direction) 
        if speed  :
            self.speed  = speed 
        else :
            self.speed  = 0.0 
    def drift (self, ) :
        '''Move the actor forward at its current velocity. If it reaches the edge of the world, wrap arround to the opposite edge.'''
        self.move(speed) 
        if self.get_x()==-399  :
            self.set_location(400,self.get_y()) 
        elif self.get_x()==400  :
            self.set_location(-399,self.get_y()) 
        elif self.get_y()==-299  :
            self.set_location(self.get_x(),300) 
        elif self.get_y()==300  :
            self.set_location(self.get_x(),-299) 
    def add_to_velocity (self,force ) :
        '''Modify our velocity by adding a velocity vector'''
        velocity_vector  = Vector(self.get_rotation(),self.speed) 
        velocity_vector.add(force) 
        self.set_rotation(velocity_vector.get_angle()) 
        n  = velocity_vector.get_angle() 
        #(=> Disabled:n  = velocity_vector.get_angle() 
        self.speed  = velocity_vector.get_length() 
    def set_velocity (self,self,direction,speed ) :
        '''Modify our velocity by adding a velocity vector'''
        self.set_rotation(direction) 
        self.speed  = speed 
class Rocket(FreeMover)  :
    def __init__ (self,x,y,tag ) :
        #Create the rocket initially slowly drifting
        __self__.super(x,y,tag,13,0.7) 
    def act (self, ) :
        drift() 
        check_keys() 
        check_collision() 
    def check_keys (self, ) :
        pass
    def check_collision (self, ) :
        pass
    def ignite (self,booster_on ) :
        '''Should the rocket be ignited?'''
        if booster_on  :
            self.set_image(rocket_with_thrust_img) 
            self.add_to_velocity(self.get_rotation(),0.3) 
        else :
            self.set_image(rocket_img) 
rocket_img  = load_image("data:image/png;base64,") 
rocket_with_thrust_img  = load_image("data:image/png;base64,") 
asteroid_img  = load_image("data:image/png;base64,") 
NUM_ASTEROIDS  = 3 
rocket  = Actor(rocket_img,0,-200,"rocket") 
asteroid  = Actor(load_image("data:image/png;base64,"),-200,100) 
score  = 0 
def setup ( ) :
    '''Set up the world. This includes creating the astronauts.'''
    set_background(load_image("data:image/jpeg;base64,")) 
    for i  in range(NUM_ASTEROIDS)  :
        asteroid  = Actor(asteroid_img,randint(-360,360),randint(-260,260),"asteroid") 
def move (actor ) :
    '''Move the rocket in the game. The rocket reacts to keypresses from the user, and when it finds an astronaut, it will pick them up (remove it from the world).'''
    actor.move(8) 
    global score 
    if key_pressed("left")  :
        rocket.turn(5) 
    if key_pressed("right")  :
        rocket.turn(-5) 
    if rocket.is_touching("astronaut")  :
        rocket.remove_touching("astronaut") 
        load_sound("data:audio/x-wav;base64,").play() 
        score  = score+20 
        rocket.say_for(str(score),1) 
        if not get_actors("astronaut")  :
            #if there are no astronauts left, land the rocket
            landing() 
def move_asteroid ( ) :
    '''Move the asteroid. The asteroid moves forward automatically. When the asteroid hits the rocket, you lose.'''
    if randint(0,99)<10  :
        '''10% chance
        '''
        asteroid.turn(randint(-40,40)) 
    if asteroid.is_touching("rocket")  :
        asteroid.remove_touching("rocket") 
        Actor(load_image("data:image/png;base64,")) 
        load_sound("data:audio/x-wav;base64,").play() 
        stop() 
def game_over ( ) :
    '''Final scene: landing the rocket.'''
    load_sound("data:audio/x-wav;base64,").play() 
    Actor(load_image("data:image/png;base64,")) 
    stop() 
#(=> Section:Main
setup() 
